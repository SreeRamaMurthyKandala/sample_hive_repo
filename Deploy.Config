###############################################################################
# Deploy.Config - HiveGrid application deployment metadata
# Consumed by the corporate CI/CD orchestrator and the HiveGrid deploy agent.
###############################################################################

AppId=shiplogistics
AppName=Shipment Logistics Analytics
AppShortDesc=Daily, weekly and monthly shipment analytics on the HiveGrid on-prem platform.
AppOwner=Logistics Analytics Team
AppOwnerGroup=grp_shiplogistics_analytics
AppEnv=PROD
Platform=HiveGrid
PlatformVersion=4.3
ServiceAccount=svc_shiplogistics
YarnQueue=shiplogistics
NotificationEmail=[REDACTED_EMAIL_ADDRESS_1]

# Database registration
SourceDB=hivesrcdb
HiveDB=shiplogistics_db
DimDB=shiplogistics_dim_db

# HDFS locations
RootPath=/corp/analytics/shiplogistics
WarehousePath=/corp/analytics/shiplogistics/warehouse
LandingPath=/corp/analytics/shiplogistics/landing
ArchivePath=/corp/analytics/shiplogistics/archive
SftOutboundPath=/corp/sft/outbound/shiplogistics

# CLI binding
HiveRunner=/corp/platform/hive/bin/hive-runner

# Versioning
Version=1.4.0
ReleaseDate=2026-05-15
ChangeRequestId=CR-LOG-2026-00184

# Job catalogue (one row per scheduled job)
Job=daily_shipment_ingest
Job=weekly_dim_refresh
Job=daily_shipment_summary
Job=monthly_shipment_export

# Event Engine registration directory
EventEngineDir=event_engine
