-- ----------------------------------------------------------------------------
-- daily_shipment_summary_filters.config
--
-- Filters applied during summary aggregation. These are kept as hivevars so
-- that downstream business owners can request scope changes (e.g. excluding
-- a service tier from the summary) without code edits.
-- ----------------------------------------------------------------------------

-- Exclude shipments whose service level is internal warehouse transfer
set hivevar:filter_excl_internal_transfer=AND s.service_level <> 'WAREHOUSE_TRANSFER';

-- Restrict to shipments whose record_type is one of the analytics types
set hivevar:filter_record_type=AND s.record_type IN ('RAW','MANIFEST');

-- Skip rows whose carrier_id failed to join (caught separately by the DQ HQL)
set hivevar:filter_joined_carrier=AND dc.carrier_id IS NOT NULL;
