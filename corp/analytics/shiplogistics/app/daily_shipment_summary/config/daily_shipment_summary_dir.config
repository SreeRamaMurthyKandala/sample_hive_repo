###############################################################################
# daily_shipment_summary_dir.config
###############################################################################

# ----- Application paths --------------------------------------------------- #
HomeDir=/corp/analytics/shiplogistics/app/daily_shipment_summary
CommonHomeDir=/corp/analytics/shiplogistics/app/common
ConfigDir=${HomeDir}/config
LogDir=${HomeDir}/logs
ScriptDir=${HomeDir}/scripts
TmpDir=${HomeDir}/tmp
HqlDir=${HomeDir}/hql
HdlDir=${HomeDir}/hdl

# ----- Job metadata -------------------------------------------------------- #
system=daily_shipment_summary
system_desc="Daily aggregated shipment summary and DQ error capture"

# ----- Cluster / queue ----------------------------------------------------- #
mapred_qname=shiplogistics

# ----- Database names ------------------------------------------------------ #
cs_db=hivesrcdb
uc_db=shiplogistics_db
dim_db=shiplogistics_dim_db

# ----- HDFS warehouse path ------------------------------------------------- #
HiveDBPath=/corp/analytics/shiplogistics/warehouse/shiplogistics_db

# ----- Date variables ------------------------------------------------------ #
trans_dt=$(date -d "-1 day" +"%Y-%m-%d")
year_month_day=$(date +"%Y%m%d")
report_month=$(date -d "-1 day" +"%Y-%m")

# ----- Error-rate warning threshold (integer percent) --------------------- #
err_rate_threshold=5

# ----- Notification -------------------------------------------------------- #
DistributionEmail=[REDACTED_EMAIL_ADDRESS_1]
