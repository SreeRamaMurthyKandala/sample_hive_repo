###############################################################################
# weekly_dim_refresh_dir.config
###############################################################################

# ----- Application paths --------------------------------------------------- #
HomeDir=/corp/analytics/shiplogistics/app/weekly_dim_refresh
CommonHomeDir=/corp/analytics/shiplogistics/app/common
ConfigDir=${HomeDir}/config
LogDir=${HomeDir}/logs
ScriptDir=${HomeDir}/scripts
TmpDir=${HomeDir}/tmp
HqlDir=${HomeDir}/hql
HdlDir=${HomeDir}/hdl

# ----- Job metadata -------------------------------------------------------- #
system=weekly_dim_refresh
system_desc="Weekly full refresh of carrier and route dimensions"

# ----- Cluster / queue ----------------------------------------------------- #
mapred_qname=shiplogistics

# ----- Database names ------------------------------------------------------ #
cs_db=hivesrcdb
uc_db=shiplogistics_db
dim_db=shiplogistics_dim_db

# ----- HDFS warehouse path ------------------------------------------------- #
HiveDBPath=/corp/analytics/shiplogistics/warehouse/shiplogistics_dim_db

# ----- Date variables ------------------------------------------------------ #
load_dt=$(date +"%Y-%m-%d")
year_month_day=$(date +"%Y%m%d")
trans_dt=$(date +"%Y-%m-%d")

# ----- Notification -------------------------------------------------------- #
DistributionEmail=[REDACTED_EMAIL_ADDRESS_1]
