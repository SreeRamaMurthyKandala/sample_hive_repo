-- ----------------------------------------------------------------------------
-- weekly_dim_refresh_filters.config
--
-- Active-record filter applied uniformly to both dimension sources. The
-- definition of "active" is:
--   status = 'A'
--   eff_dt <= load_dt
--   exp_dt IS NULL OR exp_dt >= load_dt
-- ----------------------------------------------------------------------------

set hivevar:filter_active_status=AND m.status = 'A';
set hivevar:filter_eff_dt=AND m.eff_dt <= '${hivevar:load_dt}';
set hivevar:filter_exp_dt=AND (m.exp_dt IS NULL OR m.exp_dt = '' OR m.exp_dt >= '${hivevar:load_dt}');
