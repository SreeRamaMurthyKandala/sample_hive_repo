-- ----------------------------------------------------------------------------
-- daily_shipment_ingest_filters.config
--
-- Injected into Hive at runtime via:
--   hive-runner -i ${ConfigDir}/daily_shipment_ingest_filters.config ...
--
-- Each `set hivevar:<name>=<value>;` line creates a Hive variable that can be
-- substituted into the load HQL with ${hivevar:<name>}.
-- ----------------------------------------------------------------------------

-- Exclude internal test traffic that should never appear in analytics
set hivevar:filter_excl_test_type=AND s.record_type <> 'TEST';

-- Exclude internal corporate-internal shipments (not customer-facing)
set hivevar:filter_excl_internal_type=AND s.record_type <> 'INTERNAL';

-- Keep only the in-flight or completed shipment statuses; drop intermediate
-- and clerical statuses such as CANCELLED, RETURNED, ON_HOLD
set hivevar:filter_status_code=AND s.shipment_status_code IN ('BOOKED','IN_TRANSIT','DELIVERED');

-- Drop ultra-low-value parcel manifests that the business does not analyse
set hivevar:filter_min_value=AND s.declared_value >= ${hivevar:min_declared_value};

-- Drop rows missing the carrier_id surrogate (these will never join to dim)
set hivevar:filter_non_null_carrier=AND s.carrier_id IS NOT NULL AND s.carrier_id <> '';
