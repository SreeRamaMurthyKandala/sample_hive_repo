###############################################################################
# daily_shipment_ingest_dir.config
# Sourced by the trigger shell script. Every variable defined here is
# subsequently exported and may be passed to hive-runner via -d.
###############################################################################

# ----- Application paths --------------------------------------------------- #
HomeDir=/corp/analytics/shiplogistics/app/daily_shipment_ingest
CommonHomeDir=/corp/analytics/shiplogistics/app/common
ConfigDir=${HomeDir}/config
LogDir=${HomeDir}/logs
ScriptDir=${HomeDir}/scripts
TmpDir=${HomeDir}/tmp
HqlDir=${HomeDir}/hql
HdlDir=${HomeDir}/hdl

# ----- Job metadata -------------------------------------------------------- #
system=daily_shipment_ingest
system_desc="Daily ingest of raw shipment records into the partitioned staging table"

# ----- Cluster / queue ----------------------------------------------------- #
mapred_qname=shiplogistics

# ----- Database names ------------------------------------------------------ #
cs_db=hivesrcdb
uc_db=shiplogistics_db
dim_db=shiplogistics_dim_db

# ----- HDFS warehouse path ------------------------------------------------- #
HiveDBPath=/corp/analytics/shiplogistics/warehouse/shiplogistics_db

# ----- Date variables (Linux date -d syntax) ------------------------------- #
trans_dt=$(date -d "-1 day" +"%Y-%m-%d")
year_month_day=$(date +"%Y%m%d")
year_month=$(date -d "-1 day" +"%Y-%m")

# ----- Filter thresholds (referenced by HQL via hivevars) ------------------ #
min_declared_value=10.00

# ----- Notification -------------------------------------------------------- #
DistributionEmail=[REDACTED_EMAIL_ADDRESS_1]
